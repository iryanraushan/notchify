{
  "name": "@iryanraushan/notchify",
  "version": "1.1.6",
  "description": "A classic toast notification library for React and Next.js",
  "author": "Raushan Kumar",
  "license": "MIT",
  "homepage": "https://notchify.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iryanraushan/notchify.git"
  },
  "bugs": {
    "url": "https://github.com/iryanraushan/notchify/issues"
  },
  "keywords": [
    "toast",
    "notification",
    "react",
    "nextjs",
    "ui",
    "react-toast",
    "toast-library",
    "toast-notification",
    "radix-ui",
    "typescript",
    "alert",
    "snackbar",
    "frontend",
    "component-library"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "preview": "vite",
    "preview:build": "vite build",
    "preview:dev": "vite"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=18"
  }
}
