{
  "name": "notchify-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/notchify",
    "dev:web": "npm run dev --workspace=notchify-web",
    "build:web": "npm run build --workspace=notchify-web"
  },
  "engines": {
    "node": ">=18"
  }
}
