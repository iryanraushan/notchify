{
  "name": "@iryanraushan/notchify",
  "version": "2.2.3",
  "description": "A classic toast notification library for React and Next.js",
  "author": "Raushan Kumar",
  "license": "MIT",
  "homepage": "https://notchify.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iryanraushan/notchify.git"
  },
  "bugs": {
    "url": "https://github.com/iryanraushan/notchify/issues"
  },
  "keywords": [
    "toast",
    "notification",
    "react",
    "nextjs",
    "ui",
    "react-toast",
    "toast-library",
    "toast-notification",
    "typescript",
    "alert",
    "snackbar",
    "frontend",
    "component-library"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "cp -f ../../README.md ./README.md && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsup": "^8.0.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
